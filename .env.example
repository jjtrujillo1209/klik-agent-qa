# Lead GenAI Orchestrator - Variables de Entorno
# Copia este archivo como .env y llena tus keys

# ── REQUERIDO ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OPCIONAL (enriquecimiento de contactos) ───────────────────────────────
# Apollo.io - Para emails y datos LinkedIn adicionales
APOLLO_API_KEY=

# BetterContact - Para emails verificados
BETTERCONTACT_API_KEY=

# Lusha - Para teléfonos verificados
LUSHA_API_KEY=

# HubSpot - Para deduplicación automática
HUBSPOT_API_KEY=

# ── CONFIGURACIÓN DEL SERVIDOR ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ── LINKEDIN ──────────────────────────────────────────────────────────────
# Las cookies se guardan automáticamente en linkedin_cookies.json
# Ejecuta: python setup_linkedin_auth.py para autenticar
LINKEDIN_HEADLESS=true
